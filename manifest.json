{
  "manifest_version": 3,
  "name": "FB CLI",
  "version": "1.0",
  "description": "Turns Facebook into a discreet CLI.",
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  },
  "action": {
    "default_icon": {
      "16": "icon.png",
      "48": "icon.png",
      "128": "icon.png"
    },
    "default_title": "FB CLI"
  },
  "content_scripts": [
    {
      "matches": ["*://*.facebook.com/*"],
      "css": ["styles.css"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ]
}
